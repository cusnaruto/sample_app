<%= form_for(@user) do |f| %>
  <%= render "shared/error_messages", object: @user %>

  <div class="form-group">
    <%= f.label :name, t(".name") %>
    <%= f.text_field :name, class: "form-control", placeholder: t(".name_placeholder") %>
  </div>

  <div class="form-group">
    <%= f.label :email, t(".email") %>
    <%= f.email_field :email, class: "form-control", placeholder: t(".email_placeholder") %>
  </div>

  <div class="form-group">
    <%= f.label :dob, t(".date_of_birth") %>
    <%= f.date_select :dob, { prompt: t(".select_date") }, { class: "form-control" } %>
  </div>

  <div class="form-group">
    <%= f.label :gender, t(".gender") %>
    <%= f.select :gender, options_for_select([
      [t("users.genders.male"), "male"],
      [t("users.genders.female"), "female"],
      [t("users.genders.other"), "other"]
    ], @user.gender), { prompt: t(".select_gender") }, { class: "form-control" } %>
  </div>

  <div class="form-group">
    <%= f.label :password, t(".password") %>
    <%= f.password_field :password, class: "form-control", placeholder: t(".password_placeholder") %>
  </div>

  <div class="form-group">
    <%= f.label :password_confirmation, t(".password_confirmation") %>
    <%= f.password_field :password_confirmation, class: "form-control", placeholder: t(".password_confirmation_placeholder") %>
  </div>

  <div class="form-group">
    <%= f.submit t(".submit"), class: "btn btn-primary" %>
  </div>
<% end %>
